# Telegram bot token from @BotFather
BOT_TOKEN=

# Telegram API credentials from https://my.telegram.org/apps
API_ID=
API_HASH=

# Comma-separated Telegram user IDs allowed to use the bot (required, non-empty)
ALLOWED_USERS=

# Absolute path where downloaded files are temporarily stored
DOWNLOAD_DIR=/root/tg-video-downloads

# Maximum file size in MB the bot will try to upload (Telegram MTProto limit ~2000)
MAX_UPLOAD_MB=2000

# Log level: error | warn | info | debug
LOG_LEVEL=info
